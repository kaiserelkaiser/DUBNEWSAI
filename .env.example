# Application
APP_NAME=DUBNEWSAI
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# Public URLs
PUBLIC_FRONTEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000
INTERNAL_API_URL=http://backend:8000/api/v1

# Ports
FRONTEND_PORT=3000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database
POSTGRES_USER=dubnewsai
POSTGRES_PASSWORD=CHANGE_ME_SUPER_STRONG_PASSWORD
POSTGRES_DB=dubnewsai
DATABASE_URL=postgresql+asyncpg://dubnewsai:CHANGE_ME_SUPER_STRONG_PASSWORD@postgres:5432/dubnewsai
DATABASE_URL_POOLER=
DB_ECHO=False

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Security
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["http://localhost:3000","https://your-domain.com"]
RATE_LIMIT_PER_MINUTE=60

# External Providers
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
OPENWEATHER_KEY=
RAPID_API_KEY=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=
BETTERSTACK_SOURCE_TOKEN=
BETTERSTACK_HEARTBEAT_CHECK_ID=
SENTRY_DSN=

# Optional seed values
SEED_ADMIN_EMAIL=admin@dubnewsai.com
SEED_ADMIN_NAME=DUBNEWSAI Admin
SEED_ADMIN_PASSWORD=
