# Hosted production template (Railway backend + Supabase Postgres + Upstash Redis)
# Fill this file, then copy values into Railway/Vercel environment variables.

# Application
APP_NAME=DUBNEWSAI
APP_VERSION=1.0.0
API_V1_PREFIX=/api/v1
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# Public URLs
PUBLIC_FRONTEND_URL=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app/api/v1
NEXT_PUBLIC_WS_URL=wss://your-backend.up.railway.app
INTERNAL_API_URL=https://your-backend.up.railway.app/api/v1

# Database
# Use the persistent/direct connection from Supabase for the running backend when possible.
# Keep DATABASE_URL_POOLER as an optional transaction-pooler connection for tooling if needed.
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-HOST]:5432/postgres
DATABASE_URL_POOLER=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@[YOUR-SUPABASE-POOLER-HOST]:6543/postgres?pgbouncer=true
DB_ECHO=False

# Redis / Celery
REDIS_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379/0
CELERY_BROKER_URL=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379/1
CELERY_RESULT_BACKEND=rediss://default:[PASSWORD]@[ENDPOINT].upstash.io:6379/2
UPSTASH_REDIS_REST_URL=https://[ENDPOINT].upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Security
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=["https://your-frontend.vercel.app","https://your-domain.com"]
RATE_LIMIT_PER_MINUTE=60

# External Providers
NEWSAPI_KEY=
ALPHA_VANTAGE_KEY=
OPENWEATHER_KEY=
RAPID_API_KEY=
RESEND_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=
BETTERSTACK_SOURCE_TOKEN=
BETTERSTACK_HEARTBEAT_CHECK_ID=
SENTRY_DSN=

# Optional seed values
SEED_ADMIN_EMAIL=admin@dubnewsai.com
SEED_ADMIN_NAME=DUBNEWSAI Admin
SEED_ADMIN_PASSWORD=
